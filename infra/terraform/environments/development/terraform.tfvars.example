# =============================================================================
# Example terraform.tfvars — copy to terraform.tfvars and fill in your values
# =============================================================================

aws_region      = "eu-central-1"
bedrock_region  = "eu-central-1"
project_prefix  = "claude-code-agent"

# Secrets (use TF_VAR_* env vars instead of hardcoding)
# github_token      = "github_pat_..."
# jira_token        = "jira_api_token_..."
# linear_token      = "lin_api_..."
# anthropic_api_key = "sk-ant-..."

# Networking — your VPC subnets and security groups
subnet_ids         = ["subnet-0417c686623f80fa6", "subnet-05e7d49d47de90f82"]
security_group_ids = ["sg-0d7c10ef18b64cadb"] 
assign_public_ip   = true 

# ECS task sizing
ecs_cpu    = 4096
ecs_memory = 16384

# Claude Code config
claude_model_id      = "us.anthropic.claude-sonnet-4-6"
default_repo_url     = "https://github.com/Ermiyas2146/claude-code-repo.git"
default_base_branch  = "main"
default_test_command = "npm test"
max_turns            = 50

# Monitoring
log_retention_days = 30
alarm_email        = ""
